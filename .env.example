# ============================================
# NEXUS_AI — Environment Variables (Template)
# ============================================
# INSTRUCCIONES: Copia este contenido a un archivo nuevo llamado .env.local
# y rellena los valores con tus llaves reales. 
# NUNCA subas el archivo .env.local a GitHub.

# --- CLERK (Autenticación) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_reemplazame
CLERK_SECRET_KEY=sk_test_reemplazame
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- SUPABASE (Base de Datos) ---
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui
# Formato: postgresql://postgres:[PASSWORD]@db.tu-id.supabase.co:5432/postgres
DATABASE_URL=tu-url-de-conexion-aqui

# --- ANTHROPIC (Claude AI) ---
ANTHROPIC_API_KEY=sk-ant-reemplazame

# --- STRIPE (Pagos) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_reemplazame
STRIPE_SECRET_KEY=sk_test_reemplazame
STRIPE_WEBHOOK_SECRET=whsec_reemplazame

# NOTA: Usa los IDs que empiezan con "price_", no los de "prod_"
STRIPE_PRICE_PRO_MONTHLY=price_reemplazame
STRIPE_PRICE_PRO_YEARLY=price_reemplazame

# --- CONFIGURACIÓN DE APP ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
